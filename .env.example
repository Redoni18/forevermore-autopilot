# Forevermore Autopilot — environment variables
# Copy the ones you need into the process env (launchd/systemd or a sourced
# .env). There is NO auto-loader — the daemons read the ambient process env.
# NOTE: the variable NAMES below are the ones the code actually reads
# (src/config.mjs). Earlier drafts documented KILL_SWITCH / CHROME_PATH /
# BRAIN_DRIVER / CADENCE_TZ / AUTONOMY_LEVEL — those were never read; the real
# keys are the AUTOPILOT_* forms below.

# Standalone layout (ADR-001)
FOREVERMORE_ROOT=../forevermore                    # Platform checkout (env > config > sibling). Since the §3.12 kit move this only backs template thumbnails + captures.
AUTOPILOT_DB_URL=postgres://postgres:autopilot@127.0.0.1:5433/autopilot  # Autopilot's OWN database (never the platform's)

# Brain auth — Claude subscription via the `claude` CLI (ADR/brief §3.3).
# Run `claude setup-token` ONCE (interactively); the token lasts ~1 year.
# HARD RULE: never `--bare` (it skips the OAuth token) and never wire the
# agent-sdk driver to subscription auth (SDK is API-key only).
CLAUDE_CODE_OAUTH_TOKEN=                  # from `claude setup-token`
# ANTHROPIC_API_KEY=                      # agent-sdk only; NOT for the claude-cli driver

# Brain driver + model policy (WAVE2 §3.4)
AUTOPILOT_DRIVER=claude-cli               # fixture | claude-cli | mock | agent-sdk (config key: brainDriver)
# Per-stage model pins + fallback live in autopilot.config.json (stageModels /
# fallbackModel), not env — model policy is config, not code.

# Discord control channel (WAVE2 Phase 1; pivoted from Telegram 2026-07-14 —
# Telegram signup carries a mandatory SMS fee in this region). Secrets/flags
# live in env only. All ids are snowflake STRINGS.
DISCORD_ENABLED=false                     # true to run the daemon (`autopilot bot`)
DISCORD_BOT_TOKEN=                        # developer portal → your app → Bot → Reset Token
DISCORD_CHANNEL_ID=                       # right-click your private #autopilot channel → Copy Channel ID
DISCORD_OWNER_ID=                         # right-click yourself → Copy User ID
# DISCORD_API_BASE=                       # test/dev seam only (point at a fake REST API)
# AUTOPILOT_STATION_URL=                  # deep-link target for the 🔍 Station button (Phase 2: the tunnel URL)

# Instagram publisher (Phase 3)
META_IG_TOKEN=                            # Long-lived Instagram (dev-mode) token, instagram_business_content_publish
META_IG_USER_ID=                          # IG professional account user id

# TikTok publisher (Phase 3)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=

# Email digest (deferred — AP-503; digest is local HTML today)
RESEND_API_KEY=
RESEND_FROM_EMAIL=autopilot@getforevermore.co

# Publish action-link security (Phase 3 — link_nonces)
AP_HMAC_SECRET=                           # HMAC secret for signed public action links

# Media storage (Phase 2/3 — Cloudflare R2 replaces Supabase Storage per ADR-001)
# R2_ACCOUNT_ID= / R2_ACCESS_KEY_ID= / R2_SECRET_ACCESS_KEY= / R2_BUCKET=

# Local paths & runner (config keys shown in parens)
AUTOPILOT_ROOT=                           # data root override (paths.root); defaults to repo root
AUTOPILOT_TZ=Europe/Tirane                # timezone (config: timezone)
AUTOPILOT_STORE=postgres                  # file | postgres (config: store)
AUTOPILOT_KILL_SWITCH=false               # env-forced global pause on top of settings.kill_switch
AUTOPILOT_BRAVE=                          # headless browser binary for poster render (Linux: chrome-headless-shell/chromium)
AUTOPILOT_REMOTION_GL=                    # Remotion --gl renderer; set to `swangle` on CPU-only Linux (§3.9), leave unset on macOS

# Development
DEBUG=
NODE_ENV=production

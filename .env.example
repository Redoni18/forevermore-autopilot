# Forevermore Autopilot — environment variables
# Copy this to .env and fill in actual values. All variables are required at their respective milestones.

# Claude API authentication (M0: only if using agent-sdk driver; otherwise uses subscription auth)
# Choose ONE of the following:
CLAUDE_CODE_OAUTH_TOKEN=                  # OAuth token from `claude setup-token` (recommended for CI)
# ANTHROPIC_API_KEY=                      # Fallback: direct API key (less secure in CI)

# Brain driver (M0)
BRAIN_DRIVER=claude-cli                   # Driver class: claude-cli | agent-sdk | mock

# Supabase control plane (M1)
SUPABASE_URL=                             # Production database URL (https://xxxxx.supabase.co)
SUPABASE_SERVICE_ROLE_KEY=                # Service-role key (DO NOT use anon/authenticated)

# Instagram publisher (M1; needs AP-701 setup)
META_IG_TOKEN=                            # Long-lived Instagram Graph API user token
META_IG_USER_ID=                          # IG account user ID (auto-resolved if token valid)

# TikTok publisher (M1; needs AP-702 setup)
TIKTOK_CLIENT_KEY=                        # OAuth client ID
TIKTOK_CLIENT_SECRET=                     # OAuth client secret
TIKTOK_REFRESH_TOKEN=                     # Stored refresh token (from initial OAuth)

# Email delivery (M1; Resend)
RESEND_API_KEY=                           # Resend API key for digest emails
RESEND_FROM_EMAIL=autopilot@getforevermore.co  # Sender email

# Approval link security (M1)
AP_HMAC_SECRET=                           # HMAC secret for signed approval links (48-char random)

# Media storage (M1)
SUPABASE_STORAGE_BUCKET=autopilot-media   # Bucket name for post assets
SUPABASE_STORAGE_PUBLIC_URL=              # Public CDN URL prefix (if using custom domain)

# Local paths & runner config (M0+)
AUTOPILOT_HOME=/Users/redonemini/Desktop/Code/Personal/forevermore/autopilot
AUTOPILOT_LOG_DIR=logs                    # Relative to AUTOPILOT_HOME
AUTOPILOT_OUTBOX_DIR=outbox               # M0 file-store root
AUTOPILOT_LIBRARY_DIR=library             # Capture library (product footage clips)

# Browser & rendering (M0+)
CHROME_PATH=                              # Path to Chromium/Brave (auto-detect if empty)
REMOTION_CACHE_DIR=                       # Remotion FFmpeg cache (defaults to system temp)

# Feature flags & settings (M0+)
AUTONOMY_LEVEL=1                          # L0 (dry-run) | L1 (copilot) | L2+ (advanced)
KILL_SWITCH=false                         # Global pause toggle
CADENCE_TZ=Europe/Tirane                  # Schedule timezone for launchd cron

# Development mode
DEBUG=                                    # Enable debug logging (set to "autopilot:*" for verbose)
NODE_ENV=production                       # production | development | test

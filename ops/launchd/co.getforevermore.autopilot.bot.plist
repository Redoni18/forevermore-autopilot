<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>co.getforevermore.autopilot.bot</string>
	<!-- The Discord control channel (WAVE2 Phase 1; pivoted from Telegram
	     2026-07-14 — Telegram signup carries a mandatory SMS-verification fee in
	     the owner's region). A long-lived gateway + scan daemon: a projection of
	     the DB into the owner's phone (review cards with playable media, tick
	     summaries, failure/liveness/spend alerts) and the inbound steering
	     surface (/new, /rule, /pause, freeform notes). Decisions flow through
	     the SAME decide()/store paths as the Station, so the two never disagree.
	     Own lockfile (state/bot.lock). KeepAlive restarts on crash and at boot.

	     Secrets are NOT in this file (it's committed). Put them in
	     ~/.config/autopilot/bot.env (chmod 600), which the shell sources:
	         DISCORD_ENABLED=true
	         DISCORD_BOT_TOKEN=...
	         DISCORD_CHANNEL_ID=...
	         DISCORD_OWNER_ID=...
	     On the VPS (Phase 2) this becomes a systemd unit with EnvironmentFile. -->
	<key>ProgramArguments</key>
	<array>
		<string>/bin/zsh</string>
		<string>-lc</string>
		<string>cd /Users/redonemini/Desktop/Code/Personal/forevermore-autopilot &amp;&amp; [ -f ~/.config/autopilot/bot.env ] &amp;&amp; set -a &amp;&amp; . ~/.config/autopilot/bot.env &amp;&amp; set +a; node bin/autopilot.mjs bot >> logs/launchd-bot.log 2>&amp;1</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>ThrottleInterval</key>
	<integer>30</integer>
	<!-- TimeZone: Europe/Tirane (system TZ) -->
</dict>
</plist>
